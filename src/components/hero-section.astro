---
import { about } from "../constants";
import { Image } from "astro:assets";
---

<div class="flex flex-col flex-1 text-left">
  <h1 class="text-2xl font-bold mt-4 text-zinc-900 dark:text-zinc-50">
    {about.name}
  </h1>
  <h3 class="text-xl font-semibold mb-4 text-zinc-700 dark:text-zinc-300">
    {about.title}
  </h3>
  <p
    class="font-normal text-zinc-600 dark:text-zinc-400 leading-relaxed mb-4 whitespace-pre-line"
  >
    {about.description}
  </p>
</div>

<div
  class="flex-shrink-0 rounded-full h-96 w-72 border-2 border-zinc-300 dark:border-zinc-700 overflow-hidden md:self-auto shadow"
>
  <img
    src={about.image}
    class="rounded-full w-full h-full object-cover shadow"
    alt="Sabbir Hossain Shuvo"
  />
</div>
